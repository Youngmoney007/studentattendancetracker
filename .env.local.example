# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/student-attendance-db

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-secret-key-min-32-chars-here
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars-here

# Email Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development

# University/Institution
UNIVERSITY_NAME=Your University Name
UNIVERSITY_LOCATION=University Location
